<Window
	x:Class="camera.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d">
	<Window.SystemBackdrop>
		<DesktopAcrylicBackdrop />
	</Window.SystemBackdrop>
	<StackPanel
		HorizontalAlignment="Center"
		VerticalAlignment="Center"
		Orientation="Vertical">
		<MediaPlayerElement
			x:Name="CameraPreview"
			Width="640"
			Height="360"
			HorizontalAlignment="Center"
			AreTransportControlsEnabled="False"
			Stretch="Uniform" />
		<ComboBox
			x:Name="CameraComboBox"
			Width="200"
			Margin="0,20,0,20"
			HorizontalAlignment="Center" />
		<StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
			<Button
				x:Name="GetCameraButton"
				Width="100"
				HorizontalAlignment="Center"
				Click="GetCameraButton_Click"
				Content="Get Camera" />
			<Button
				x:Name="StartCameraButton"
				Margin="10,0,0,0"
				Click="StartCameraButton_Click"
				Content="Start Camera" />
			<Button
				x:Name="StopCameraButton"
				Margin="10,0,0,0"
				Click="StopCameraButton_Click"
				Content="Stop Camera" />
		</StackPanel>
		<TextBlock x:Name="StatusTextBlock" Margin="0,20,0,0" />
	</StackPanel>
</Window>
