<Window
	x:Class="paint.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d">

	<Window.SystemBackdrop>
		<DesktopAcrylicBackdrop />
	</Window.SystemBackdrop>

	<Grid>
		<Grid.Resources>
			<!--  图标按钮通用样式：无内边距、内容居中、固定 36×36  -->
			<Style
				x:Key="IconButtonStyle"
				BasedOn="{StaticResource DefaultButtonStyle}"
				TargetType="Button">
				<Setter Property="Width" Value="36" />
				<Setter Property="Height" Value="36" />
				<Setter Property="Padding" Value="0" />
				<Setter Property="HorizontalContentAlignment" Value="Center" />
				<Setter Property="VerticalContentAlignment" Value="Center" />
			</Style>
			<Style
				x:Key="IconToggleButtonStyle"
				BasedOn="{StaticResource DefaultToggleButtonStyle}"
				TargetType="ToggleButton">
				<Setter Property="Width" Value="36" />
				<Setter Property="Height" Value="36" />
				<Setter Property="Padding" Value="0" />
				<Setter Property="HorizontalContentAlignment" Value="Center" />
				<Setter Property="VerticalContentAlignment" Value="Center" />
			</Style>
		</Grid.Resources>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!--  ═══════════════════════════════════════════════════════  -->
		<!--  顶部工具栏 (mspaint 风格)  -->
		<!--  ═══════════════════════════════════════════════════════  -->
		<Border
			Grid.Row="0"
			Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
			BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
			BorderThickness="0,0,0,1">
			<StackPanel
				Padding="8,4"
				VerticalAlignment="Center"
				Orientation="Horizontal"
				Spacing="6">

				<!--  ── 绘图工具切换 (ToggleButton + PathIcon) ──  -->
				<ToggleButton
					x:Name="PenToolButton"
					Checked="ToolButton_Checked"
					IsChecked="True"
					Style="{StaticResource IconToggleButtonStyle}"
					ToolTipService.ToolTip="画笔"
					Unchecked="ToolButton_Unchecked">
					<FontIcon
						FontFamily="Segoe Fluent Icons"
						FontSize="16"
						Glyph="&#xE771;" />
				</ToggleButton>
				<ToggleButton
					x:Name="LineToolButton"
					Checked="ToolButton_Checked"
					Style="{StaticResource IconToggleButtonStyle}"
					ToolTipService.ToolTip="直线"
					Unchecked="ToolButton_Unchecked">
					<Grid Width="16" Height="16">
						<Line
							x:Name="LineButtonIcon"
							Stroke="{ThemeResource TextFillColorPrimaryBrush}"
							StrokeEndLineCap="Round"
							StrokeStartLineCap="Round"
							StrokeThickness="1"
							X1="0"
							X2="16"
							Y1="8"
							Y2="8" />
					</Grid>
				</ToggleButton>
				<ToggleButton
					x:Name="RectToolButton"
					Checked="ToolButton_Checked"
					Style="{StaticResource IconToggleButtonStyle}"
					ToolTipService.ToolTip="矩形"
					Unchecked="ToolButton_Unchecked">
					<Border
						x:Name="RectButtonIcon"
						Width="16"
						Height="14"
						BorderBrush="{ThemeResource TextFillColorPrimaryBrush}"
						BorderThickness="1" />
				</ToggleButton>
				<ToggleButton
					x:Name="EllipseToolButton"
					Checked="ToolButton_Checked"
					Style="{StaticResource IconToggleButtonStyle}"
					ToolTipService.ToolTip="圆形"
					Unchecked="ToolButton_Unchecked">
					<FontIcon
						FontFamily="Segoe Fluent Icons"
						FontSize="16"
						Glyph="&#xEA3A;" />
				</ToggleButton>

				<!--  分隔线  -->
				<Border
					Width="1"
					Height="24"
					Margin="4,0"
					VerticalAlignment="Center"
					Background="{ThemeResource TextFillColorSecondaryBrush}" />

				<!--  ── 笔触粗细 ──  -->
				<TextBlock
					VerticalAlignment="Center"
					FontSize="12"
					Foreground="{ThemeResource TextFillColorSecondaryBrush}"
					Text="粗细:" />
				<Slider
					x:Name="ThicknessSlider"
					Width="80"
					VerticalAlignment="Center"
					Maximum="20"
					Minimum="1"
					StepFrequency="1"
					Value="3" />
				<TextBlock
					x:Name="ThicknessLabel"
					MinWidth="32"
					VerticalAlignment="Center"
					FontSize="12"
					Foreground="{ThemeResource TextFillColorSecondaryBrush}"
					Text="3 px" />

				<!--  分隔线  -->
				<Border
					Width="1"
					Height="24"
					Margin="4,0"
					VerticalAlignment="Center"
					Background="{ThemeResource TextFillColorSecondaryBrush}" />

				<!--  ── 取色器 (颜色预览按钮 + Flyout) ──  -->
				<Button
					x:Name="ColorButton"
					Width="36"
					Height="36"
					Padding="4"
					BorderThickness="0"
					ToolTipService.ToolTip="笔触颜色">
					<Button.Flyout>
						<Flyout Placement="BottomEdgeAlignedLeft">
							<Flyout.FlyoutPresenterStyle>
								<Style TargetType="FlyoutPresenter">
									<Setter Property="Padding" Value="12" />
								</Style>
							</Flyout.FlyoutPresenterStyle>
							<StackPanel Spacing="12">
								<!--  完整 ColorPicker  -->
								<ColorPicker
									x:Name="BrushColorPicker"
									ColorChanged="BrushColorPicker_ColorChanged"
									ColorSpectrumShape="Ring"
									IsAlphaEnabled="False"
									IsColorChannelTextInputVisible="False"
									IsHexInputVisible="False"
									Color="Black" />

								<!--  预制色  -->
								<TextBlock
									FontSize="12"
									FontWeight="SemiBold"
									Foreground="{ThemeResource TextFillColorSecondaryBrush}"
									Text="预制色" />
								<StackPanel x:Name="PresetColorPanel" Spacing="4" />
							</StackPanel>
						</Flyout>
					</Button.Flyout>
					<!--  颜色预览色块  -->
					<Rectangle
						x:Name="ColorPreviewRect"
						Width="22"
						Height="22"
						RadiusX="2"
						RadiusY="2"
						Stroke="{ThemeResource TextFillColorSecondaryBrush}"
						StrokeThickness="1">
						<Rectangle.Fill>
							<SolidColorBrush x:Name="ColorPreviewBrush" Color="Black" />
						</Rectangle.Fill>
					</Rectangle>
				</Button>

				<!--  分隔线  -->
				<Border
					Width="1"
					Height="24"
					Margin="4,0"
					VerticalAlignment="Center"
					Background="{ThemeResource TextFillColorSecondaryBrush}" />

				<!--  ── 操作按钮 (Undo / Clear) ──  -->
				<Button
					x:Name="UndoButton"
					Click="UndoButton_Click"
					IsEnabled="False"
					Style="{StaticResource IconButtonStyle}"
					ToolTipService.ToolTip="撤销">
					<FontIcon
						FontFamily="Segoe Fluent Icons"
						FontSize="16"
						Glyph="&#xE7A7;" />
				</Button>
				<Button
					x:Name="ClearButton"
					Click="ClearButton_Click"
					IsEnabled="False"
					Style="{StaticResource IconButtonStyle}"
					ToolTipService.ToolTip="清空画板">
					<FontIcon
						FontFamily="Segoe Fluent Icons"
						FontSize="16"
						Glyph="&#xED62;" />
				</Button>

			</StackPanel>
		</Border>

		<!--  ═══════════════════════════════════════════════════════  -->
		<!--  绘图画布  -->
		<!--  ═══════════════════════════════════════════════════════  -->
		<canvas:CanvasControl
			x:Name="PaintCanvas"
			Grid.Row="1"
			ClearColor="White"
			Draw="PaintCanvas_Draw"
			PointerExited="PaintCanvas_PointerReleased"
			PointerMoved="PaintCanvas_PointerMoved"
			PointerPressed="PaintCanvas_PointerPressed"
			PointerReleased="PaintCanvas_PointerReleased" />
	</Grid>
</Window>
