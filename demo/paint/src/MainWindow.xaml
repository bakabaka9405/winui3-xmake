<Window
	x:Class="paint.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
	mc:Ignorable="d">

	<Window.SystemBackdrop>
		<DesktopAcrylicBackdrop />
	</Window.SystemBackdrop>

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="280" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<!-- 左侧工具面板 -->
		<ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
			<StackPanel Padding="12" Spacing="16">

				<!-- 标题 -->
				<TextBlock Text="Paint Demo"
					FontSize="20"
					FontWeight="SemiBold" />

				<!-- 绘图工具选择 -->
				<StackPanel Spacing="8">
					<TextBlock Text="绘图工具"
						FontWeight="SemiBold"
						FontSize="14" />
					<RadioButton x:Name="PenTool"
						Content="画笔 (Pen)"
						IsChecked="True"
						GroupName="ToolGroup" />
					<RadioButton x:Name="LineTool"
						Content="直线 (Line)"
						GroupName="ToolGroup" />
					<RadioButton x:Name="RectTool"
						Content="矩形 (Rectangle)"
						GroupName="ToolGroup" />
					<RadioButton x:Name="EllipseTool"
						Content="椭圆 (Ellipse)"
						GroupName="ToolGroup" />
				</StackPanel>

				<!-- 颜色选择器 -->
				<StackPanel Spacing="8">
					<TextBlock Text="笔触颜色"
						FontWeight="SemiBold"
						FontSize="14" />
					<ColorPicker x:Name="BrushColorPicker"
						Color="Black"
						ColorChanged="BrushColorPicker_ColorChanged" />
				</StackPanel>

				<!-- 笔触粗细 -->
				<StackPanel Spacing="8">
					<TextBlock Text="笔触粗细"
						FontWeight="SemiBold"
						FontSize="14" />
					<Slider x:Name="ThicknessSlider"
						Minimum="1"
						Maximum="20"
						Value="3"
						StepFrequency="1"
						TickFrequency="1"
						TickPlacement="Outside" />
					<TextBlock x:Name="ThicknessLabel"
						Text="3 px"
						HorizontalAlignment="Right"
						FontSize="12"
						Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
				</StackPanel>

				<!-- 操作按钮 -->
				<StackPanel Spacing="8">
					<Button x:Name="UndoButton"
						Content="撤销 (Undo)"
						Click="UndoButton_Click"
						IsEnabled="False" />
					<Button x:Name="ClearButton"
						Content="清空画板 (Clear)"
						Click="ClearButton_Click"
						IsEnabled="False" />
				</StackPanel>

			</StackPanel>
		</ScrollViewer>

		<!-- 右侧绘图画布 -->
		<canvas:CanvasControl
			Grid.Column="1"
			x:Name="PaintCanvas"
			Draw="PaintCanvas_Draw"
			ClearColor="White"
			PointerPressed="PaintCanvas_PointerPressed"
			PointerMoved="PaintCanvas_PointerMoved"
			PointerReleased="PaintCanvas_PointerReleased"
			PointerExited="PaintCanvas_PointerReleased" />
	</Grid>
</Window>
