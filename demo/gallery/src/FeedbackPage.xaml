<Page
    x:Class="gallery.FeedbackPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  ═══ Left: Demo Area ═══  -->
        <ScrollViewer Padding="24,16" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">

                <!--  Determinate ProgressBar  -->
                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="ProgressBar (Determinate)" />
                <ProgressBar
                    x:Name="DemoProgressBar"
                    MinWidth="300"
                    HorizontalAlignment="Left"
                    Maximum="100"
                    Value="30"
                    ValueChanged="DemoProgressBar_ValueChanged" />

                <!--  Indeterminate ProgressBar  -->
                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="ProgressBar (Indeterminate)" />
                <ProgressBar
                    x:Name="DemoIndeterminateBar"
                    MinWidth="300"
                    HorizontalAlignment="Left"
                    IsIndeterminate="True" />

                <!--  ProgressRing  -->
                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="ProgressRing" />
                <ProgressRing
                    x:Name="DemoProgressRing"
                    HorizontalAlignment="Left"
                    IsActive="True" />

                <!--  InfoBar  -->
                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="InfoBar" />
                <InfoBar
                    x:Name="DemoInfoBar"
                    Title="Information"
                    IsClosable="True"
                    IsOpen="True"
                    Message="This is a demo info bar."
                    Severity="Informational"
                    CloseButtonClick="DemoInfoBar_CloseButtonClick">
                    <InfoBar.ActionButton>
                        <Button Click="InfoBarAction_Click" Content="Action" />
                    </InfoBar.ActionButton>
                </InfoBar>

            </StackPanel>
        </ScrollViewer>

        <!--  ═══ Right: Property Panel ═══  -->
        <ScrollViewer
            Grid.Column="1"
            Padding="16,16"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="8">

                <!--  Determinate ProgressBar Properties  -->
                <TextBlock Style="{StaticResource PropGroupStyle}" Text="Determinate ProgressBar" />

                <TextBlock Style="{StaticResource PropLabelStyle}" Text="Value" />
                <Slider
                    x:Name="ProgressBarValueSlider"
                    Maximum="100"
                    Minimum="0"
                    StepFrequency="1"
                    ValueChanged="ProgressBarValueSlider_ValueChanged"
                    Value="30" />

                <ToggleSwitch
                    x:Name="ProgressBarIndeterminateToggle"
                    Header="IsIndeterminate"
                    IsOn="False"
                    Toggled="ProgressBarIndeterminateToggle_Toggled" />

                <ToggleSwitch
                    x:Name="ProgressBarShowPausedToggle"
                    Header="ShowPaused"
                    IsOn="False"
                    Toggled="ProgressBarShowPausedToggle_Toggled" />

                <ToggleSwitch
                    x:Name="ProgressBarShowErrorToggle"
                    Header="ShowError"
                    IsOn="False"
                    Toggled="ProgressBarShowErrorToggle_Toggled" />

                <TextBlock Style="{StaticResource PropLabelStyle}" Text="Width" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Slider
                        x:Name="ProgressBarWidthSlider"
                        Width="160"
                        Minimum="100"
                        Maximum="600"
                        StepFrequency="10"
                        Value="300"
                        ValueChanged="ProgressBarWidthSlider_ValueChanged" />
                    <TextBlock
                        x:Name="ProgressBarWidthLabel"
                        VerticalAlignment="Center"
                        Text="300" />
                </StackPanel>

                <TextBlock Style="{StaticResource PropLabelStyle}" Text="Minimum" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Slider
                        x:Name="ProgressBarMinSlider"
                        Width="160"
                        Minimum="0"
                        Maximum="100"
                        StepFrequency="1"
                        Value="0"
                        ValueChanged="ProgressBarMinSlider_ValueChanged" />
                    <TextBlock
                        x:Name="ProgressBarMinLabel"
                        VerticalAlignment="Center"
                        Text="0" />
                </StackPanel>

                <!--  ProgressRing Properties  -->
                <TextBlock Style="{StaticResource PropGroupStyle}" Text="ProgressRing" />

                <ToggleSwitch
                    x:Name="ProgressRingActiveToggle"
                    Header="IsActive"
                    IsOn="True"
                    Toggled="ProgressRingActiveToggle_Toggled" />

                <TextBlock Style="{StaticResource PropLabelStyle}" Text="Width" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Slider
                        x:Name="ProgressRingWidthSlider"
                        Width="160"
                        Minimum="16"
                        Maximum="200"
                        StepFrequency="4"
                        Value="32"
                        ValueChanged="ProgressRingWidthSlider_ValueChanged" />
                    <TextBlock
                        x:Name="ProgressRingWidthLabel"
                        VerticalAlignment="Center"
                        Text="32" />
                </StackPanel>

                <TextBlock Style="{StaticResource PropLabelStyle}" Text="Height" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Slider
                        x:Name="ProgressRingHeightSlider"
                        Width="160"
                        Minimum="16"
                        Maximum="200"
                        StepFrequency="4"
                        Value="32"
                        ValueChanged="ProgressRingHeightSlider_ValueChanged" />
                    <TextBlock
                        x:Name="ProgressRingHeightLabel"
                        VerticalAlignment="Center"
                        Text="32" />
                </StackPanel>

                <ToggleSwitch
                    x:Name="ProgressRingDeterminateToggle"
                    Header="Determinate"
                    IsOn="False"
                    Toggled="ProgressRingDeterminateToggle_Toggled" />

                <TextBlock
                    x:Name="ProgressRingValueLabel"
                    Style="{StaticResource PropLabelStyle}"
                    Text="Value"
                    Visibility="Collapsed" />
                <Slider
                    x:Name="ProgressRingValueSlider"
                    Minimum="0"
                    Maximum="100"
                    StepFrequency="1"
                    Value="0"
                    ValueChanged="ProgressRingValueSlider_ValueChanged"
                    Visibility="Collapsed" />

                <!--  InfoBar Properties  -->
                <TextBlock Style="{StaticResource PropGroupStyle}" Text="InfoBar" />

                <TextBlock Style="{StaticResource PropLabelStyle}" Text="Severity" />
                <ComboBox
                    x:Name="InfoBarSeverityCombo"
                    SelectedIndex="0"
                    SelectionChanged="InfoBarSeverityCombo_SelectionChanged">
                    <ComboBoxItem Content="Informational" />
                    <ComboBoxItem Content="Success" />
                    <ComboBoxItem Content="Warning" />
                    <ComboBoxItem Content="Error" />
                </ComboBox>

                <TextBlock Style="{StaticResource PropLabelStyle}" Text="Title" />
                <TextBox
                    x:Name="InfoBarTitleBox"
                    Text="Information"
                    TextChanged="InfoBarTitleBox_TextChanged" />

                <TextBlock Style="{StaticResource PropLabelStyle}" Text="Message" />
                <TextBox
                    x:Name="InfoBarMessageBox"
                    Text="This is a demo info bar."
                    TextChanged="InfoBarMessageBox_TextChanged" />

                <ToggleSwitch
                    x:Name="InfoBarClosableToggle"
                    Header="IsClosable"
                    IsOn="True"
                    Toggled="InfoBarClosableToggle_Toggled" />

                <ToggleSwitch
                    x:Name="InfoBarOpenToggle"
                    Header="IsOpen"
                    IsOn="True"
                    Toggled="InfoBarOpenToggle_Toggled" />

                <ToggleSwitch
                    x:Name="InfoBarIconVisibleToggle"
                    Header="IsIconVisible"
                    IsOn="True"
                    Toggled="InfoBarIconVisibleToggle_Toggled" />

                <TextBlock Style="{StaticResource PropLabelStyle}" Text="ActionButton" />
                <TextBox
                    x:Name="InfoBarActionButtonBox"
                    Text="Action"
                    TextChanged="InfoBarActionButtonBox_TextChanged" />

                <TextBlock Style="{StaticResource PropLabelStyle}" Text="Width" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Slider
                        x:Name="InfoBarWidthSlider"
                        Width="160"
                        Minimum="200"
                        Maximum="800"
                        StepFrequency="10"
                        Value="400"
                        ValueChanged="InfoBarWidthSlider_ValueChanged" />
                    <TextBlock
                        x:Name="InfoBarWidthLabel"
                        VerticalAlignment="Center"
                        Text="400" />
                </StackPanel>

                <!--  Indeterminate ProgressBar Properties  -->
                <TextBlock Style="{StaticResource PropGroupStyle}" Text="Indeterminate ProgressBar" />

                <TextBlock Style="{StaticResource PropLabelStyle}" Text="Width" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Slider
                        x:Name="IndeterminateBarWidthSlider"
                        Width="160"
                        Minimum="100"
                        Maximum="600"
                        StepFrequency="10"
                        Value="300"
                        ValueChanged="IndeterminateBarWidthSlider_ValueChanged" />
                    <TextBlock
                        x:Name="IndeterminateBarWidthLabel"
                        VerticalAlignment="Center"
                        Text="300" />
                </StackPanel>

                <ToggleSwitch
                    x:Name="IndeterminateBarShowPausedToggle"
                    Header="ShowPaused"
                    IsOn="False"
                    Toggled="IndeterminateBarShowPausedToggle_Toggled" />

                <ToggleSwitch
                    x:Name="IndeterminateBarShowErrorToggle"
                    Header="ShowError"
                    IsOn="False"
                    Toggled="IndeterminateBarShowErrorToggle_Toggled" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
