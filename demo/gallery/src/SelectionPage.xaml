<Page
    x:Class="gallery.SelectionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  ═══ Left: Demo Area ═══  -->
        <ScrollViewer Padding="24,16" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">

                <!--  ComboBox (static items)  -->
                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="ComboBox" />
                <ComboBox
                    x:Name="DemoComboBox"
                    MinWidth="200"
                    HorizontalAlignment="Left"
                    Header="Static Items"
                    SelectionChanged="OnComboSelectionChanged">
                    <ComboBoxItem Content="Item 1" />
                    <ComboBoxItem Content="Item 2" />
                    <ComboBoxItem Content="Item 3" />
                    <ComboBoxItem Content="Item 4" />
                    <ComboBoxItem Content="Item 5" />
                </ComboBox>

                <!--  Editable ComboBox  -->
                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Editable ComboBox" />
                <ComboBox
                    x:Name="DemoEditableComboBox"
                    MinWidth="200"
                    HorizontalAlignment="Left"
                    Header="Editable"
                    IsEditable="True"
                    PlaceholderText="Type or select a color..."
                    SelectionChanged="OnComboSelectionChanged" />

                <!--  ListBox  -->
                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="ListBox" />
                <ListBox
                    x:Name="DemoListBox"
                    MinWidth="180"
                    SelectionChanged="OnListBoxSelectionChanged" />

                <!--  ListView  -->
                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="ListView" />
                <ListView
                    x:Name="DemoListView"
                    MinWidth="300"
                    SelectionChanged="OnListViewSelectionChanged" />

                <!--  GridView  -->
                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="GridView" />
                <GridView
                    x:Name="DemoGridView"
                    MinWidth="300"
                    SelectionChanged="OnGridViewSelectionChanged" />

                <!--  Status Text  -->
                <Border
                    Margin="0,12,0,0"
                    Padding="0,12,0,0"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="0,1,0,0">
                    <StackPanel Spacing="4">
                        <TextBlock FontWeight="SemiBold" Text="Selection Status" />
                        <TextBlock
                            x:Name="StatusText"
                            Foreground="{ThemeResource SystemControlForegroundAccentBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!--  ═══ Right: Property Panel ═══  -->
        <ScrollViewer
            Grid.Column="1"
            Padding="16,16"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="8">

                <!--  ═══ ComboBox Properties ═══  -->
                <TextBlock Style="{StaticResource PropGroupStyle}" Text="ComboBox" />

                <ToggleSwitch
                    x:Name="ComboEditableToggle"
                    Header="IsEditable"
                    IsOn="True"
                    Toggled="OnComboEditableToggled" />

                <TextBlock
                    x:Name="ComboWidthLabel"
                    Style="{StaticResource PropLabelStyle}"
                    Text="Width: 200" />
                <Slider
                    x:Name="ComboWidthSlider"
                    Maximum="400"
                    Minimum="80"
                    StepFrequency="10"
                    Value="200"
                    ValueChanged="OnComboWidthChanged" />

                <TextBlock
                    x:Name="ComboPlaceholderLabel"
                    Style="{StaticResource PropLabelStyle}"
                    Text="PlaceholderText" />
                <TextBox
                    x:Name="ComboPlaceholderBox"
                    Text="Type or select a color..."
                    TextChanged="OnComboPlaceholderChanged" />

                <TextBlock
                    x:Name="ComboDropDownLabel"
                    Style="{StaticResource PropLabelStyle}"
                    Text="MaxDropDownHeight: 200" />
                <Slider
                    x:Name="ComboDropDownSlider"
                    Maximum="400"
                    Minimum="100"
                    StepFrequency="10"
                    Value="200"
                    ValueChanged="OnComboDropDownHeightChanged" />

                <!--  ═══ ListBox Properties ═══  -->
                <TextBlock Style="{StaticResource PropGroupStyle}" Text="ListBox" />

                <TextBlock Style="{StaticResource PropLabelStyle}" Text="SelectionMode" />
                <ComboBox
                    x:Name="ListBoxSelectionMode"
                    SelectedIndex="0"
                    SelectionChanged="OnListBoxSelectionModeChanged">
                    <ComboBoxItem Content="Single" />
                    <ComboBoxItem Content="Multiple" />
                    <ComboBoxItem Content="Extended" />
                </ComboBox>

                <TextBlock
                    x:Name="ListBoxWidthLabel"
                    Style="{StaticResource PropLabelStyle}"
                    Text="Width: 180" />
                <Slider
                    x:Name="ListBoxWidthSlider"
                    Maximum="400"
                    Minimum="60"
                    StepFrequency="10"
                    Value="180"
                    ValueChanged="OnListBoxWidthChanged" />

                <TextBlock
                    x:Name="ListBoxHeightLabel"
                    Style="{StaticResource PropLabelStyle}"
                    Text="Height: 160" />
                <Slider
                    x:Name="ListBoxHeightSlider"
                    Maximum="400"
                    Minimum="60"
                    StepFrequency="10"
                    Value="160"
                    ValueChanged="OnListBoxHeightChanged" />

                <ToggleSwitch
                    x:Name="ListBoxEnabledToggle"
                    Header="IsEnabled"
                    IsOn="True"
                    Toggled="OnListBoxEnabledToggled" />

                <!--  ═══ ListView Properties ═══  -->
                <TextBlock Style="{StaticResource PropGroupStyle}" Text="ListView" />

                <TextBlock Style="{StaticResource PropLabelStyle}" Text="SelectionMode" />
                <ComboBox
                    x:Name="ListViewSelectionMode"
                    SelectedIndex="1"
                    SelectionChanged="OnListViewSelectionModeChanged">
                    <ComboBoxItem Content="None" />
                    <ComboBoxItem Content="Single" />
                    <ComboBoxItem Content="Multiple" />
                    <ComboBoxItem Content="Extended" />
                </ComboBox>

                <ToggleSwitch
                    x:Name="ListViewItemClickToggle"
                    Header="IsItemClickEnabled"
                    Toggled="OnListViewItemClickToggled" />

                <TextBlock
                    x:Name="ListViewWidthLabel"
                    Style="{StaticResource PropLabelStyle}"
                    Text="Width: 300" />
                <Slider
                    x:Name="ListViewWidthSlider"
                    Maximum="500"
                    Minimum="100"
                    StepFrequency="10"
                    Value="300"
                    ValueChanged="OnListViewWidthChanged" />

                <TextBlock
                    x:Name="ListViewHeightLabel"
                    Style="{StaticResource PropLabelStyle}"
                    Text="Height: 180" />
                <Slider
                    x:Name="ListViewHeightSlider"
                    Maximum="300"
                    Minimum="60"
                    StepFrequency="10"
                    Value="180"
                    ValueChanged="OnListViewHeightChanged" />

                <ToggleSwitch
                    x:Name="ListViewScrollingToggle"
                    Header="ShowsScrollingPlaceholders"
                    IsOn="False"
                    Toggled="OnListViewScrollingPlaceholdersToggled" />

                <ToggleSwitch
                    x:Name="ListViewEnabledToggle"
                    Header="IsEnabled"
                    IsOn="True"
                    Toggled="OnListViewEnabledToggled" />

                <!--  ═══ GridView Properties ═══  -->
                <TextBlock Style="{StaticResource PropGroupStyle}" Text="GridView" />

                <TextBlock Style="{StaticResource PropLabelStyle}" Text="SelectionMode" />
                <ComboBox
                    x:Name="GridViewSelectionMode"
                    SelectedIndex="1"
                    SelectionChanged="OnGridViewSelectionModeChanged">
                    <ComboBoxItem Content="None" />
                    <ComboBoxItem Content="Single" />
                    <ComboBoxItem Content="Multiple" />
                    <ComboBoxItem Content="Extended" />
                </ComboBox>

                <TextBlock
                    x:Name="GridViewWidthLabel"
                    Style="{StaticResource PropLabelStyle}"
                    Text="Width: 300" />
                <Slider
                    x:Name="GridViewWidthSlider"
                    Maximum="500"
                    Minimum="100"
                    StepFrequency="10"
                    Value="300"
                    ValueChanged="OnGridViewWidthChanged" />

                <TextBlock
                    x:Name="GridViewHeightLabel"
                    Style="{StaticResource PropLabelStyle}"
                    Text="Height: 200" />
                <Slider
                    x:Name="GridViewHeightSlider"
                    Maximum="300"
                    Minimum="60"
                    StepFrequency="10"
                    Value="200"
                    ValueChanged="OnGridViewHeightChanged" />

                <ToggleSwitch
                    x:Name="GridViewEnabledToggle"
                    Header="IsEnabled"
                    IsOn="True"
                    Toggled="OnGridViewEnabledToggled" />

                <TextBlock
                    x:Name="GridViewItemInfo"
                    Style="{StaticResource PropLabelStyle}"
                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
