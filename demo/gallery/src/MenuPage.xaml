<Page
    x:Class="gallery.MenuPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  ===== Left: Demo Area =====  -->
        <ScrollViewer Grid.Column="0">
            <StackPanel Margin="16" Spacing="16">

                <!--  MenuBar Block  -->
                <Border
                    Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">

                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="MenuBar" />

                        <MenuBar x:Name="DemoMenuBar">
                            <MenuBarItem Title="File">
                                <MenuFlyoutItem Click="MenuNew_Click" Text="New">
                                    <MenuFlyoutItem.KeyboardAccelerators>
                                        <KeyboardAccelerator Key="N" Modifiers="Control" />
                                    </MenuFlyoutItem.KeyboardAccelerators>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Click="MenuOpen_Click" Text="Open">
                                    <MenuFlyoutItem.KeyboardAccelerators>
                                        <KeyboardAccelerator Key="O" Modifiers="Control" />
                                    </MenuFlyoutItem.KeyboardAccelerators>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Click="MenuSave_Click" Text="Save">
                                    <MenuFlyoutItem.KeyboardAccelerators>
                                        <KeyboardAccelerator Key="S" Modifiers="Control" />
                                    </MenuFlyoutItem.KeyboardAccelerators>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Click="MenuExit_Click" Text="Exit" />
                            </MenuBarItem>

                            <MenuBarItem Title="Edit">
                                <MenuFlyoutItem Click="MenuUndo_Click" Text="Undo">
                                    <MenuFlyoutItem.KeyboardAccelerators>
                                        <KeyboardAccelerator Key="Z" Modifiers="Control" />
                                    </MenuFlyoutItem.KeyboardAccelerators>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Click="MenuRedo_Click" Text="Redo">
                                    <MenuFlyoutItem.KeyboardAccelerators>
                                        <KeyboardAccelerator Key="Y" Modifiers="Control" />
                                    </MenuFlyoutItem.KeyboardAccelerators>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Click="MenuCut_Click" Text="Cut">
                                    <MenuFlyoutItem.KeyboardAccelerators>
                                        <KeyboardAccelerator Key="X" Modifiers="Control" />
                                    </MenuFlyoutItem.KeyboardAccelerators>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Click="MenuCopy_Click" Text="Copy">
                                    <MenuFlyoutItem.KeyboardAccelerators>
                                        <KeyboardAccelerator Key="C" Modifiers="Control" />
                                    </MenuFlyoutItem.KeyboardAccelerators>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Click="MenuPaste_Click" Text="Paste">
                                    <MenuFlyoutItem.KeyboardAccelerators>
                                        <KeyboardAccelerator Key="V" Modifiers="Control" />
                                    </MenuFlyoutItem.KeyboardAccelerators>
                                </MenuFlyoutItem>
                            </MenuBarItem>

                            <MenuBarItem Title="Help">
                                <MenuFlyoutItem Click="MenuAbout_Click" Text="About">
                                    <MenuFlyoutItem.KeyboardAccelerators>
                                        <KeyboardAccelerator Key="F1" />
                                    </MenuFlyoutItem.KeyboardAccelerators>
                                </MenuFlyoutItem>
                            </MenuBarItem>
                        </MenuBar>

                    </StackPanel>
                </Border>

                <!--  CommandBar Block  -->
                <Border
                    Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">

                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="CommandBar" />

                        <CommandBar x:Name="DemoCommandBar" Opening="DemoCommandBar_Opening" Closed="DemoCommandBar_Closed">
                            <CommandBar.PrimaryCommands>
                                <AppBarButton
                                    Click="AddButton_Click"
                                    Icon="Add"
                                    Label="Add" />
                                <AppBarButton
                                    Click="EditButton_Click"
                                    Icon="Edit"
                                    Label="Edit" />
                                <AppBarButton
                                    Click="DeleteButton_Click"
                                    Icon="Delete"
                                    Label="Delete" />
                            </CommandBar.PrimaryCommands>
                            <CommandBar.SecondaryCommands>
                                <AppBarButton
                                    Click="SettingsButton_Click"
                                    Icon="Setting"
                                    Label="Settings" />
                                <AppBarButton
                                    Click="ShareButton_Click"
                                    Icon="Share"
                                    Label="Share" />
                            </CommandBar.SecondaryCommands>
                        </CommandBar>

                    </StackPanel>
                </Border>

                <!--  Status Block  -->
                <Border
                    Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">

                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Status" />

                        <TextBlock
                            x:Name="StatusText"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="No action yet"
                            TextWrapping="Wrap" />

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!--  ===== Right: Property Editors =====  -->
        <ScrollViewer Grid.Column="1">
            <StackPanel Margin="0,16,16,16" Spacing="12">

                <!--  CommandBar Settings  -->
                <Border
                    Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="CommandBar Settings" />

                        <TextBlock Style="{StaticResource PropLabelStyle}" Text="Is Open" />
                        <ToggleSwitch
                            x:Name="OpenSwitch"
                            IsOn="False"
                            Toggled="OpenSwitch_Toggled" />

                        <TextBlock Style="{StaticResource PropLabelStyle}" Text="Default Label Position" />
                        <ComboBox
                            x:Name="LabelPositionCombo"
                            SelectedIndex="0"
                            SelectionChanged="LabelPositionCombo_SelectionChanged">
                            <ComboBoxItem Content="Right" />
                            <ComboBoxItem Content="Bottom" />
                            <ComboBoxItem Content="Collapsed" />
                        </ComboBox>

                        <TextBlock Style="{StaticResource PropLabelStyle}" Text="Overflow Button Visibility" />
                        <ComboBox
                            x:Name="OverflowVisibilityCombo"
                            SelectedIndex="0"
                            SelectionChanged="OverflowVisibilityCombo_SelectionChanged">
                            <ComboBoxItem Content="Auto" />
                            <ComboBoxItem Content="Visible" />
                            <ComboBoxItem Content="Collapsed" />
                        </ComboBox>

                        <TextBlock Style="{StaticResource PropLabelStyle}" Text="Is Sticky" />
                        <ToggleSwitch
                            x:Name="StickySwitch"
                            IsOn="False"
                            Toggled="StickySwitch_Toggled" />

                        <TextBlock Style="{StaticResource PropLabelStyle}" Text="Closed Display Mode" />
                        <ComboBox
                            x:Name="ClosedDisplayModeCombo"
                            SelectedIndex="0"
                            SelectionChanged="ClosedDisplayModeCombo_SelectionChanged">
                            <ComboBoxItem Content="Compact" />
                            <ComboBoxItem Content="Minimal" />
                            <ComboBoxItem Content="Hidden" />
                        </ComboBox>

                        <TextBlock Style="{StaticResource PropLabelStyle}" Text="Width" />
                        <TextBlock
                            x:Name="CmdBarWidthLabel"
                            Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="400" />
                        <Slider
                            x:Name="CmdBarWidthSlider"
                            Minimum="200"
                            Maximum="800"
                            StepFrequency="10"
                            ValueChanged="CmdBarWidthSlider_ValueChanged"
                            Value="400" />

                    </StackPanel>
                </Border>

                <!--  MenuBar Settings  -->
                <Border
                    Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="MenuBar Settings" />

                        <TextBlock Style="{StaticResource PropLabelStyle}" Text="Is Enabled" />
                        <ToggleSwitch
                            x:Name="MenuBarEnabledSwitch"
                            IsOn="True"
                            Toggled="MenuBarEnabledSwitch_Toggled" />

                        <TextBlock Style="{StaticResource PropLabelStyle}" Text="Flow Direction" />
                        <ComboBox
                            x:Name="MenuBarFlowDirectionCombo"
                            SelectedIndex="0"
                            SelectionChanged="MenuBarFlowDirectionCombo_SelectionChanged">
                            <ComboBoxItem Content="LeftToRight" />
                            <ComboBoxItem Content="RightToLeft" />
                        </ComboBox>

                        <TextBlock Style="{StaticResource PropLabelStyle}" Text="Width" />
                        <TextBlock
                            x:Name="MenuBarWidthLabel"
                            Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="400" />
                        <Slider
                            x:Name="MenuBarWidthSlider"
                            Minimum="200"
                            Maximum="800"
                            StepFrequency="10"
                            ValueChanged="MenuBarWidthSlider_ValueChanged"
                            Value="400" />

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</Page>
