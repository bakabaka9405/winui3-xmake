<Page
    x:Class="gallery.DialogFlyoutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  ═══ Left: Demo Area ═══  -->
        <ScrollViewer Padding="24,16" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">

                <!--  ContentDialog  -->
                <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="ContentDialog" />
                <Button
                    x:Name="ShowDialogBtn"
                    HorizontalAlignment="Left"
                    Click="OnShowDialogClick"
                    Content="Show ContentDialog" />

                <!--  Flyout  -->
                <TextBlock
                    Margin="0,20,0,4"
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="Flyout" />
                <Button
                    x:Name="DemoFlyoutButton"
                    HorizontalAlignment="Left"
                    Content="Show Flyout">
                    <Button.Flyout>
                        <Flyout x:Name="DemoFlyout" Placement="Top">
                            <StackPanel Padding="12" Spacing="8">
                                <TextBlock Text="Enter some text:" />
                                <TextBox
                                    x:Name="FlyoutTextBox"
                                    Width="220"
                                    PlaceholderText="Type here..." />
                                <Button
                                    HorizontalAlignment="Right"
                                    Click="OnFlyoutOkClick"
                                    Content="OK" />
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <!--  MenuFlyout  -->
                <TextBlock
                    Margin="0,20,0,4"
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="MenuFlyout" />
                <Button
                    x:Name="DemoMenuFlyoutButton"
                    HorizontalAlignment="Left"
                    Content="Show MenuFlyout">
                    <Button.Flyout>
                        <MenuFlyout x:Name="DemoMenuFlyout">
                            <MenuFlyoutItem Click="OnCutClick" Text="Cut">
                                <MenuFlyoutItem.Icon>
                                    <SymbolIcon Symbol="Cut" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Click="OnCopyClick" Text="Copy">
                                <MenuFlyoutItem.Icon>
                                    <SymbolIcon Symbol="Copy" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Click="OnPasteClick" Text="Paste">
                                <MenuFlyoutItem.Icon>
                                    <SymbolIcon Symbol="Paste" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <!--  TeachingTip  -->
                <TextBlock
                    Margin="0,20,0,4"
                    Style="{StaticResource SectionHeaderStyle}"
                    Text="TeachingTip" />
                <TeachingTip
                    x:Name="DemoTeachingTip"
                    Title="Tip"
                    IsLightDismissEnabled="True"
                    Subtitle="This is a teaching tip" />
                <Button
                    x:Name="DemoTeachingTipButton"
                    HorizontalAlignment="Left"
                    Click="OnShowTeachingTipClick"
                    Content="Show TeachingTip" />

                <!--  Status  -->
                <Border
                    Margin="0,8,0,0"
                    Padding="0,12,0,0"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="0,1,0,0">
            <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Status" />
                        <TextBlock
                            x:Name="StatusText"
                            Foreground="{ThemeResource SystemControlForegroundAccentBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!--  ═══ Right: Property Editors ═══  -->
        <ScrollViewer
            Grid.Column="1"
            Padding="16,16"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="8">

                <!--  ContentDialog Properties  -->
                <TextBlock Style="{StaticResource PropGroupStyle}" Text="ContentDialog" />
                <TextBlock Style="{StaticResource PropLabelStyle}" Text="Title" />
                <TextBox
                    x:Name="DialogTitleBox"
                    PlaceholderText="Title"
                    Text="Dialog Title" />
                <TextBlock Style="{StaticResource PropLabelStyle}" Text="Content" />
                <TextBox
                    x:Name="DialogContentBox"
                    Height="60"
                    AcceptsReturn="True"
                    PlaceholderText="Content"
                    Text="This is the dialog content." />
                <TextBlock Style="{StaticResource PropLabelStyle}" Text="PrimaryButtonText" />
                <TextBox
                    x:Name="DialogPrimaryBtnText"
                    PlaceholderText="Primary button text"
                    Text="OK" />
                <TextBlock Style="{StaticResource PropLabelStyle}" Text="SecondaryButtonText" />
                <TextBox
                    x:Name="DialogSecondaryBtnText"
                    PlaceholderText="Secondary button text (empty to hide)" />
                <TextBlock Style="{StaticResource PropLabelStyle}" Text="CloseButtonText" />
                <TextBox
                    x:Name="DialogCloseBtnText"
                    PlaceholderText="Close button text"
                    Text="Cancel" />
                <TextBlock Style="{StaticResource PropLabelStyle}" Text="DefaultButton" />
                <ComboBox
                    x:Name="DialogDefaultBtnCombo"
                    SelectedIndex="1">
                    <ComboBoxItem Content="None" />
                    <ComboBoxItem Content="Primary" />
                    <ComboBoxItem Content="Secondary" />
                    <ComboBoxItem Content="Close" />
                </ComboBox>

                <!--  Flyout Properties  -->
                <TextBlock Style="{StaticResource PropGroupStyle}" Text="Flyout" />
                <TextBlock Style="{StaticResource PropLabelStyle}" Text="Placement" />
                <ComboBox
                    x:Name="FlyoutPlacementCombo"
                    SelectedIndex="0"
                    SelectionChanged="OnFlyoutPlacementChanged">
                    <ComboBoxItem Content="Top" />
                    <ComboBoxItem Content="Bottom" />
                    <ComboBoxItem Content="Left" />
                    <ComboBoxItem Content="Right" />
                    <ComboBoxItem Content="Full" />
                </ComboBox>
                <TextBlock Style="{StaticResource PropLabelStyle}" Text="ShowMode" />
                <ComboBox
                    x:Name="FlyoutShowModeCombo"
                    SelectedIndex="0"
                    SelectionChanged="OnFlyoutShowModeChanged">
                    <ComboBoxItem Content="Standard" />
                    <ComboBoxItem Content="Transient" />
                    <ComboBoxItem Content="TransientWithDismissOnPointerMoveAway" />
                </ComboBox>
                <TextBlock Style="{StaticResource PropLabelStyle}" Text="Flyout TextBox Width" />
                <Slider
                    x:Name="FlyoutWidthSlider"
                    Width="200"
                    Minimum="100"
                    Maximum="400"
                    StepFrequency="10"
                    Value="220"
                    ValueChanged="OnFlyoutWidthChanged" />
                <TextBlock Style="{StaticResource PropLabelStyle}" Text="LightDismissOverlayMode" />
                <ComboBox
                    x:Name="FlyoutLightDismissCombo"
                    SelectedIndex="0"
                    SelectionChanged="OnFlyoutLightDismissChanged">
                    <ComboBoxItem Content="Auto" />
                    <ComboBoxItem Content="On" />
                    <ComboBoxItem Content="Off" />
                </ComboBox>

                <!--  MenuFlyout Properties  -->
                <TextBlock Style="{StaticResource PropGroupStyle}" Text="MenuFlyout" />
                <TextBlock Style="{StaticResource PropLabelStyle}" Text="Placement" />
                <ComboBox
                    x:Name="MenuFlyoutPlacementCombo"
                    SelectedIndex="0"
                    SelectionChanged="OnMenuFlyoutPlacementChanged">
                    <ComboBoxItem Content="Top" />
                    <ComboBoxItem Content="Bottom" />
                    <ComboBoxItem Content="Left" />
                    <ComboBoxItem Content="Right" />
                    <ComboBoxItem Content="Full" />
                </ComboBox>

                <!--  TeachingTip Properties  -->
                <TextBlock Style="{StaticResource PropGroupStyle}" Text="TeachingTip" />
                <ToggleSwitch
                    x:Name="TeachingTipLightDismissSwitch"
                    Header="IsLightDismissEnabled"
                    IsOn="True"
                    Toggled="OnTeachingTipLightDismissToggled" />
                <TextBlock Style="{StaticResource PropLabelStyle}" Text="PreferredPlacement" />
                <ComboBox
                    x:Name="TeachingTipPlacementCombo"
                    SelectedIndex="0"
                    SelectionChanged="OnTeachingTipPlacementChanged">
                    <ComboBoxItem Content="Auto" />
                    <ComboBoxItem Content="Top" />
                    <ComboBoxItem Content="Bottom" />
                    <ComboBoxItem Content="Left" />
                    <ComboBoxItem Content="Right" />
                    <ComboBoxItem Content="TopLeft" />
                    <ComboBoxItem Content="TopRight" />
                    <ComboBoxItem Content="BottomLeft" />
                    <ComboBoxItem Content="BottomRight" />
                </ComboBox>
                <TextBlock Style="{StaticResource PropLabelStyle}" Text="Title" />
                <TextBox
                    x:Name="TeachingTipTitleBox"
                    Text="Tip"
                    TextChanged="OnTeachingTipTitleChanged" />
                <TextBlock Style="{StaticResource PropLabelStyle}" Text="Subtitle" />
                <TextBox
                    x:Name="TeachingTipSubtitleBox"
                    Text="This is a teaching tip"
                    TextChanged="OnTeachingTipSubtitleChanged" />

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
