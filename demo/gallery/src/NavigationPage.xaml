<Page
    x:Class="gallery.NavigationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  ===== Left: Demo Area =====  -->
        <ScrollViewer Grid.Column="0">
            <StackPanel Margin="16" Spacing="16">

                <!--  TabView Block  -->
                <Border
                    Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">

                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="TabView" />

                        <TabView
                            x:Name="DemoTabView"
                            Height="250"
                            AddTabButtonClick="DemoTabView_AddTabButtonClick"
                            TabCloseRequested="DemoTabView_TabCloseRequested"
                            SelectionChanged="DemoTabView_SelectionChanged">
                            <TabView.TabItems>
                                <TabViewItem Header="Document 1">
                                    <TextBlock
                                        Margin="16"
                                        Style="{StaticResource BodyTextBlockStyle}"
                                        Text="Content of Document 1" />
                                </TabViewItem>
                                <TabViewItem Header="Document 2">
                                    <TextBlock
                                        Margin="16"
                                        Style="{StaticResource BodyTextBlockStyle}"
                                        Text="Content of Document 2" />
                                </TabViewItem>
                                <TabViewItem Header="Document 3">
                                    <TextBlock
                                        Margin="16"
                                        Style="{StaticResource BodyTextBlockStyle}"
                                        Text="Content of Document 3" />
                                </TabViewItem>
                            </TabView.TabItems>
                        </TabView>

                    </StackPanel>
                </Border>

                <!--  PipsPager Block  -->
                <Border
                    Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">

                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="PipsPager" />

                        <!--  Page indicator  -->
                        <TextBlock
                            x:Name="PipsPageLabel"
                            HorizontalAlignment="Center"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="Page 1 of 5" />

                        <!--  PipsPager  -->
                        <PipsPager
                            x:Name="DemoPipsPager"
                            HorizontalAlignment="Center"
                            NumberOfPages="5"
                            SelectedIndexChanged="DemoPipsPager_SelectedIndexChanged" />

                        <!--  Prev / Next row  -->
                        <StackPanel
                            HorizontalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="12">
                            <Button
                                x:Name="PipsPrevButton"
                                Click="PipsPrevButton_Click"
                                Content="◀ Prev" />
                            <Button
                                x:Name="PipsNextButton"
                                Click="PipsNextButton_Click"
                                Content="Next ▶" />
                        </StackPanel>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!--  ===== Right: Property Editors =====  -->
        <ScrollViewer Grid.Column="1">
            <StackPanel Margin="0,16,16,16" Spacing="12">

                <!--  TabView Properties  -->
                <Border
                    Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="TabView Settings" />

                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="Can Close Tabs" />
                        <ToggleSwitch
                            x:Name="CanCloseTabsSwitch"
                            IsOn="True"
                            Toggled="CanCloseTabsSwitch_Toggled" />

                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="Show Add Button" />
                        <ToggleSwitch
                            x:Name="IsAddTabVisibleSwitch"
                            IsOn="True"
                            Toggled="IsAddTabVisibleSwitch_Toggled" />

                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="Tab Width Mode" />
                        <ComboBox
                            x:Name="TabWidthModeCombo"
                            SelectedIndex="0"
                            SelectionChanged="TabWidthModeCombo_SelectionChanged">
                            <ComboBoxItem Content="Equal" />
                            <ComboBoxItem Content="SizeToContent" />
                            <ComboBoxItem Content="Compact" />
                        </ComboBox>

                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="Tab Strip Header" />
                        <TextBox
                            x:Name="TabStripHeaderBox"
                            PlaceholderText="Enter header text..."
                            TextChanged="TabStripHeaderBox_TextChanged" />

                        <TextBlock
                            x:Name="TabStripFooterLabel"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="Tab Count: 3" />

                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="Selected Tab Index" />
                        <Slider
                            x:Name="TabSelectedIndexSlider"
                            Maximum="2"
                            Minimum="0"
                            StepFrequency="1"
                            TickFrequency="1"
                            ValueChanged="TabSelectedIndexSlider_ValueChanged"
                            Value="0" />
                    </StackPanel>
                </Border>

                <!--  PipsPager Properties  -->
                <Border
                    Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="PipsPager Settings" />

                        <TextBlock
                            x:Name="NumPagesLabel"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="Number of Pages: 5" />
                        <Slider
                            x:Name="NumPagesSlider"
                            Maximum="10"
                            Minimum="1"
                            StepFrequency="1"
                            TickFrequency="1"
                            ValueChanged="NumPagesSlider_ValueChanged"
                            Value="5" />

                        <TextBlock
                            x:Name="MaxVisibleLabel"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="Max Visible Pips: 5" />
                        <Slider
                            x:Name="MaxVisiblePipsSlider"
                            Maximum="10"
                            Minimum="1"
                            StepFrequency="1"
                            TickFrequency="1"
                            ValueChanged="MaxVisiblePipsSlider_ValueChanged"
                            Value="5" />

                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="Orientation" />
                        <ComboBox
                            x:Name="PipsOrientationCombo"
                            SelectedIndex="0"
                            SelectionChanged="PipsOrientationCombo_SelectionChanged">
                            <ComboBoxItem Content="Horizontal" />
                            <ComboBoxItem Content="Vertical" />
                        </ComboBox>

                        <TextBlock
                            x:Name="PipsPageIndexLabel"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="Selected Page Index: 1" />
                        <Slider
                            x:Name="PipsPageIndexSlider"
                            Maximum="5"
                            Minimum="1"
                            StepFrequency="1"
                            TickFrequency="1"
                            ValueChanged="PipsPageIndexSlider_ValueChanged"
                            Value="1" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</Page>
