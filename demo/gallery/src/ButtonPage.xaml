<Page
    x:Class="gallery.ButtonPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <Grid Margin="16" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  ═══════════════════════════════════════════  -->
            <!--  Left: Control Demos  -->
            <!--  ═══════════════════════════════════════════  -->
            <StackPanel Grid.Column="0" Spacing="16">

                <!--  1. Button  -->
                <Border
                    Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Button" />
                        <Button
                            x:Name="DemoButton"
                            Height="32"
                            MinWidth="120"
                            HorizontalAlignment="Left"
                            Click="DemoButton_Click"
                            Content="Click Me" />
                        <TextBlock
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="A standard button that raises a Click event."
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!--  2. ToggleButton  -->
                <Border
                    Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="ToggleButton" />
                        <ToggleButton
                            x:Name="DemoToggleButton"
                            MinWidth="120"
                            HorizontalAlignment="Left"
                            Checked="DemoToggleButton_Changed"
                            Content="Toggle"
                            Unchecked="DemoToggleButton_Changed" />
                        <TextBlock
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="A button that can be toggled between two states."
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!--  3. SplitButton  -->
                <Border
                    Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="SplitButton" />
                        <SplitButton
                            x:Name="DemoSplitButton"
                            MinWidth="120"
                            HorizontalAlignment="Left"
                            Content="Split">
                            <SplitButton.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Option 1" />
                                    <MenuFlyoutItem Text="Option 2" />
                                    <MenuFlyoutItem Text="Option 3" />
                                </MenuFlyout>
                            </SplitButton.Flyout>
                        </SplitButton>
                        <TextBlock
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="A button with a primary action and a secondary flyout."
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!--  4. DropDownButton  -->
                <Border
                    Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="DropDownButton" />
                        <DropDownButton
                            x:Name="DemoDropDownButton"
                            MinWidth="120"
                            HorizontalAlignment="Left"
                            Content="DropDown">
                            <DropDownButton.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Action A" />
                                    <MenuFlyoutItem Text="Action B" />
                                    <MenuFlyoutItem Text="Action C" />
                                </MenuFlyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>
                        <TextBlock
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="A button that opens a menu flyout when clicked."
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!--  5. RepeatButton  -->
                <Border
                    Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="RepeatButton" />
                        <StackPanel
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="12">
                            <RepeatButton
                                x:Name="DemoRepeatButton"
                                Width="120"
                                Height="40"
                                Click="DemoRepeatButton_Click"
                                Content="Hold Me"
                                Delay="300"
                                Interval="100" />
                            <TextBlock
                                x:Name="RepeatCountText"
                                VerticalAlignment="Center"
                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                Text="Count: 0" />
                        </StackPanel>
                        <TextBlock
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="A button that fires Click repeatedly while pressed. Hold to see counter increment."
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!--  6. HyperlinkButton  -->
                <Border
                    Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="HyperlinkButton" />
                        <HyperlinkButton
                            x:Name="DemoHyperlink"
                            HorizontalAlignment="Left"
                            Content="Learn More"
                            NavigateUri="https://microsoft.com" />
                        <TextBlock
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="A button styled as a hyperlink. Opens the specified URI."
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!--  7. CheckBox  -->
                <Border
                    Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="CheckBox" />
                        <CheckBox
                            x:Name="DemoCheckBox"
                            Checked="DemoCheckBox_Changed"
                            MinHeight="32"
                            Unchecked="DemoCheckBox_Changed"
                            Indeterminate="DemoCheckBox_Changed"
                            Content="Check me" />
                        <TextBlock
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="A checkbox that supports two or three states."
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!--  8. RadioButtons  -->
                <Border
                    Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="RadioButtons" />
                        <RadioButtons
                            x:Name="DemoRadioGroup"
                            Header="Choose an option"
                            MaxColumns="3">
                            <RadioButton Content="Option A" />
                            <RadioButton Content="Option B" />
                            <RadioButton Content="Option C" />
                        </RadioButtons>
                        <TextBlock
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="A group of mutually exclusive radio buttons."
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!--  9. ToggleSwitch  -->
                <Border
                    Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="ToggleSwitch" />
                        <ToggleSwitch
                            x:Name="DemoToggleSwitch"
                            Header="Toggle Switch"
                            Toggled="DemoToggleSwitch_Toggled" />
                        <TextBlock
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="A switch control for binary on/off settings."
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!--  10. Status  -->
                <Border
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Status" />
                        <TextBlock
                            x:Name="StatusText"
                            Foreground="{ThemeResource SystemControlForegroundAccentBrush}"
                            Text="No action yet"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

            </StackPanel>

            <!--  ═══════════════════════════════════════════  -->
            <!--  Right: Property Editors  -->
            <!--  ═══════════════════════════════════════════  -->
            <ScrollViewer Grid.Column="1" Margin="0,16,16,16">
                <StackPanel Spacing="12">

                    <!--  Button Settings  -->
                    <Expander Header="Button Settings" IsExpanded="True">
                        <StackPanel Spacing="10">
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Content" />
                            <TextBox
                                x:Name="EditorBtnContent"
                                Text="Click Me"
                                TextChanged="EditorBtnContent_TextChanged" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Width" />
                            <TextBlock
                                x:Name="BtnWidthLabel"
                                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="120" />
                            <Slider
                                x:Name="EditorBtnWidth"
                                Maximum="400"
                                Minimum="50"
                                StepFrequency="10"
                                ValueChanged="EditorBtnWidth_ValueChanged"
                                Value="120" />
                            <ToggleSwitch
                                x:Name="EditorBtnEnabled"
                                Header="IsEnabled"
                                IsOn="True"
                                Toggled="EditorBtnEnabled_Toggled" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Visibility" />
                            <ComboBox
                                x:Name="EditorBtnVisibility"
                                SelectedIndex="0"
                                SelectionChanged="EditorBtnVisibility_SelectionChanged">
                                <ComboBoxItem Content="Visible" />
                                <ComboBoxItem Content="Collapsed" />
                            </ComboBox>
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="CornerRadius" />
                            <TextBlock
                                x:Name="BtnCornerRadiusLabel"
                                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="0" />
                            <Slider
                                x:Name="EditorBtnCornerRadius"
                                Maximum="20"
                                Minimum="0"
                                StepFrequency="1"
                                ValueChanged="EditorBtnCornerRadius_ValueChanged"
                                Value="0" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="FontSize" />
                            <TextBlock
                                x:Name="BtnFontSizeLabel"
                                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="14" />
                            <Slider
                                x:Name="EditorBtnFontSize"
                                Maximum="36"
                                Minimum="8"
                                StepFrequency="1"
                                ValueChanged="EditorBtnFontSize_ValueChanged"
                                Value="14" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="HorizontalAlignment" />
                            <ComboBox
                                x:Name="EditorBtnAlignment"
                                SelectedIndex="1"
                                SelectionChanged="EditorBtnAlignment_SelectionChanged">
                                <ComboBoxItem Content="Stretch" />
                                <ComboBoxItem Content="Left" />
                                <ComboBoxItem Content="Center" />
                                <ComboBoxItem Content="Right" />
                            </ComboBox>
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Tooltip" />
                            <TextBox
                                x:Name="EditorBtnTooltip"
                                PlaceholderText="Enter tooltip text"
                                Text=""
                                TextChanged="EditorBtnTooltip_TextChanged" />
                        </StackPanel>
                    </Expander>

                    <!--  ToggleButton Settings  -->
                    <Expander Header="ToggleButton Settings">
                        <StackPanel Spacing="10">
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Content" />
                            <TextBox
                                x:Name="EditorToggleContent"
                                Text="Toggle"
                                TextChanged="EditorToggleContent_TextChanged" />
                            <ToggleSwitch
                                x:Name="EditorToggleChecked"
                                Header="IsChecked"
                                Toggled="EditorToggleChecked_Toggled" />
                            <ToggleSwitch
                                x:Name="EditorToggleEnabled"
                                Header="IsEnabled"
                                IsOn="True"
                                Toggled="EditorToggleEnabled_Toggled" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Width" />
                            <TextBlock
                                x:Name="TglWidthLabel"
                                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="120" />
                            <Slider
                                x:Name="EditorToggleWidth"
                                Maximum="400"
                                Minimum="50"
                                StepFrequency="10"
                                ValueChanged="EditorToggleWidth_ValueChanged"
                                Value="120" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Height" />
                            <TextBlock
                                x:Name="TglHeightLabel"
                                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="32" />
                            <Slider
                                x:Name="EditorToggleHeight"
                                Maximum="200"
                                Minimum="20"
                                StepFrequency="4"
                                ValueChanged="EditorToggleHeight_ValueChanged"
                                Value="32" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="HorizontalAlignment" />
                            <ComboBox
                                x:Name="EditorToggleAlignment"
                                SelectedIndex="1"
                                SelectionChanged="EditorToggleAlignment_SelectionChanged">
                                <ComboBoxItem Content="Stretch" />
                                <ComboBoxItem Content="Left" />
                                <ComboBoxItem Content="Center" />
                                <ComboBoxItem Content="Right" />
                            </ComboBox>
                        </StackPanel>
                    </Expander>

                    <!--  SplitButton Settings  -->
                    <Expander Header="SplitButton Settings">
                        <StackPanel Spacing="10">
                            <ToggleSwitch
                                x:Name="EditorSplitEnabled"
                                Header="IsEnabled"
                                IsOn="True"
                                Toggled="EditorSplitEnabled_Toggled" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Width" />
                            <Slider
                                x:Name="EditorSplitWidth"
                                Maximum="400"
                                Minimum="50"
                                StepFrequency="10"
                                ValueChanged="EditorSplitWidth_ValueChanged"
                                Value="120" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Height" />
                            <Slider
                                x:Name="EditorSplitHeight"
                                Maximum="200"
                                Minimum="20"
                                StepFrequency="4"
                                ValueChanged="EditorSplitHeight_ValueChanged"
                                Value="32" />
                        </StackPanel>
                    </Expander>

                    <!--  DropDownButton Settings  -->
                    <Expander Header="DropDownButton Settings">
                        <StackPanel Spacing="10">
                            <ToggleSwitch
                                x:Name="EditorDropEnabled"
                                Header="IsEnabled"
                                IsOn="True"
                                Toggled="EditorDropEnabled_Toggled" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Width" />
                            <Slider
                                x:Name="EditorDropWidth"
                                Maximum="400"
                                Minimum="50"
                                StepFrequency="10"
                                ValueChanged="EditorDropWidth_ValueChanged"
                                Value="120" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Height" />
                            <Slider
                                x:Name="EditorDropHeight"
                                Maximum="200"
                                Minimum="20"
                                StepFrequency="4"
                                ValueChanged="EditorDropHeight_ValueChanged"
                                Value="32" />
                        </StackPanel>
                    </Expander>

                    <!--  RepeatButton Settings  -->
                    <Expander Header="RepeatButton Settings">
                        <StackPanel Spacing="10">
                            <ToggleSwitch
                                x:Name="EditorRepeatEnabled"
                                Header="IsEnabled"
                                IsOn="True"
                                Toggled="EditorRepeatEnabled_Toggled" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Content" />
                            <TextBox
                                x:Name="EditorRepeatContent"
                                Text="Hold Me"
                                TextChanged="EditorRepeatContent_TextChanged" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Width" />
                            <Slider
                                x:Name="EditorRepeatWidth"
                                Maximum="400"
                                Minimum="50"
                                StepFrequency="10"
                                ValueChanged="EditorRepeatWidth_ValueChanged"
                                Value="120" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Height" />
                            <Slider
                                x:Name="EditorRepeatHeight"
                                Maximum="200"
                                Minimum="20"
                                StepFrequency="4"
                                ValueChanged="EditorRepeatHeight_ValueChanged"
                                Value="40" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="HorizontalAlignment" />
                            <ComboBox
                                x:Name="EditorRepeatAlignment"
                                SelectedIndex="1"
                                SelectionChanged="EditorRepeatAlignment_SelectionChanged">
                                <ComboBoxItem Content="Stretch" />
                                <ComboBoxItem Content="Left" />
                                <ComboBoxItem Content="Center" />
                                <ComboBoxItem Content="Right" />
                            </ComboBox>
                        </StackPanel>
                    </Expander>

                    <!--  HyperlinkButton Settings  -->
                    <Expander Header="HyperlinkButton Settings">
                        <StackPanel Spacing="10">
                            <ToggleSwitch
                                x:Name="EditorHyperlinkEnabled"
                                Header="IsEnabled"
                                IsOn="True"
                                Toggled="EditorHyperlinkEnabled_Toggled" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Width" />
                            <Slider
                                x:Name="EditorHyperlinkWidth"
                                Maximum="400"
                                Minimum="50"
                                StepFrequency="10"
                                ValueChanged="EditorHyperlinkWidth_ValueChanged"
                                Value="120" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Height" />
                            <Slider
                                x:Name="EditorHyperlinkHeight"
                                Maximum="200"
                                Minimum="20"
                                StepFrequency="4"
                                ValueChanged="EditorHyperlinkHeight_ValueChanged"
                                Value="32" />
                        </StackPanel>
                    </Expander>

                    <!--  CheckBox Settings  -->
                    <Expander Header="CheckBox Settings">
                        <StackPanel Spacing="10">
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Content" />
                            <TextBox
                                x:Name="EditorCheckContent"
                                Text="Check me"
                                TextChanged="EditorCheckContent_TextChanged" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="IsChecked" />
                            <ComboBox
                                x:Name="EditorCheckChecked"
                                SelectedIndex="0"
                                SelectionChanged="EditorCheckChecked_SelectionChanged">
                                <ComboBoxItem Content="Unchecked" />
                                <ComboBoxItem Content="Checked" />
                                <ComboBoxItem Content="Indeterminate" />
                            </ComboBox>
                            <ToggleSwitch
                                x:Name="EditorCheckThreeState"
                                Header="IsThreeState"
                                Toggled="EditorCheckThreeState_Toggled" />
                            <ToggleSwitch
                                x:Name="EditorCheckEnabled"
                                Header="IsEnabled"
                                IsOn="True"
                                Toggled="EditorCheckEnabled_Toggled" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Width" />
                            <TextBlock
                                x:Name="ChkWidthLabel"
                                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="120" />
                            <Slider
                                x:Name="EditorCheckWidth"
                                Maximum="400"
                                Minimum="50"
                                StepFrequency="10"
                                ValueChanged="EditorCheckWidth_ValueChanged"
                                Value="120" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="FontSize" />
                            <TextBlock
                                x:Name="ChkFontSizeLabel"
                                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="14" />
                            <Slider
                                x:Name="EditorCheckFontSize"
                                Maximum="24"
                                Minimum="8"
                                StepFrequency="1"
                                ValueChanged="EditorCheckFontSize_ValueChanged"
                                Value="14" />
                        </StackPanel>
                    </Expander>

                    <!--  RadioButtons Settings  -->
                    <Expander Header="RadioButtons Settings">
                        <StackPanel Spacing="10">
                            <ToggleSwitch
                                x:Name="EditorRadioEnabled"
                                Header="IsEnabled"
                                IsOn="True"
                                Toggled="EditorRadioEnabled_Toggled" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Width" />
                            <Slider
                                x:Name="EditorRadioWidth"
                                Maximum="500"
                                Minimum="100"
                                StepFrequency="10"
                                ValueChanged="EditorRadioWidth_ValueChanged"
                                Value="280" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Height" />
                            <Slider
                                x:Name="EditorRadioHeight"
                                Maximum="300"
                                Minimum="40"
                                StepFrequency="10"
                                ValueChanged="EditorRadioHeight_ValueChanged"
                                Value="100" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="HorizontalAlignment" />
                            <ComboBox
                                x:Name="EditorRadioAlignment"
                                SelectedIndex="1"
                                SelectionChanged="EditorRadioAlignment_SelectionChanged">
                                <ComboBoxItem Content="Stretch" />
                                <ComboBoxItem Content="Left" />
                                <ComboBoxItem Content="Center" />
                                <ComboBoxItem Content="Right" />
                            </ComboBox>
                        </StackPanel>
                    </Expander>

                    <!--  ToggleSwitch Settings  -->
                    <Expander Header="ToggleSwitch Settings">
                        <StackPanel Spacing="10">
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Header" />
                            <TextBox
                                x:Name="EditorSwitchHeader"
                                Text="Toggle Switch"
                                TextChanged="EditorSwitchHeader_TextChanged" />
                            <ToggleSwitch
                                x:Name="EditorSwitchOn"
                                Header="IsOn"
                                Toggled="EditorSwitchOn_Toggled" />
                            <ToggleSwitch
                                x:Name="EditorSwitchEnabled"
                                Header="IsEnabled"
                                IsOn="True"
                                Toggled="EditorSwitchEnabled_Toggled" />
                            <TextBlock Style="{StaticResource PropLabelStyle}" Text="Width" />
                            <TextBlock
                                x:Name="SwWidthLabel"
                                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="120" />
                            <Slider
                                x:Name="EditorSwitchWidth"
                                Maximum="400"
                                Minimum="50"
                                StepFrequency="10"
                                ValueChanged="EditorSwitchWidth_ValueChanged"
                                Value="120" />
                        </StackPanel>
                    </Expander>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </ScrollViewer>

</Page>
